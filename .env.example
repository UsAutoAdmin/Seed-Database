# Copy this file to .env.local in this directory (project root) and replace the values below.
# Required for the phantom scraper. Get both from Supabase: Project Settings → API.

# Supabase project URL (e.g. https://abcdefgh.supabase.co — "Project URL" on API page)
NEXT_PUBLIC_SUPABASE_URL=

# Service role key (long string under "Project API keys" — anon key will not work; keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for sold-listing verification (sold count >= 60 → LLM confidence 0-1). Prefer Anthropic if set.
ANTHROPIC_API_KEY=
# Or OpenAI (used only when ANTHROPIC_API_KEY is not set)
OPENAI_API_KEY=
